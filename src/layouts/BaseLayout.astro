---
import Header from "@/components/common/Header/Header.astro";
import Footer from "@/components/common/Footer/Footer.astro";
import { defaultLng } from "@/config/language";
import { routes } from "@/config/routes";
import type { SchemaGraph } from "@/types/structure";
import type { CommonTextsI } from "@/types/texts";
import type { MetatagsI } from "@/components/common/MetaTags";
import MetaTags from "@/components/common/MetaTags/MetaTags.astro";

import "../assets/styles/style.base.css";
import "../assets/styles/style.min.css";
import "../generated/theme.css";

interface Props {
  schema?: SchemaGraph;
  commonTexts: CommonTextsI;
  metatags: MetatagsI;
}

const { schema, commonTexts, metatags } = Astro.props;

const currentLang = defaultLng;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const navItems = Object.entries(routes).map(([key, cfg]) => ({
  key,
  label: commonTexts.header[key] || cfg.label,
  href: key === "home" ? "/" : `/${key}`,
  active: key === "home" ? pathname === "/" : pathname === `/${key}`,
}));
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <MetaTags {...metatags} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- FAVICONS START -->
    <!-- FAVICONS END -->
  </head>
  <body>
    <div class="wrapper">
      <main class="page">
        <slot />
      </main>

      <Header
        navItems={navItems}
        loginLabel={commonTexts.buttons?.login || "LOGIN"}
        downloadLabel={commonTexts.buttons?.download || "DOWNLOAD"}
      />
      <Footer texts={commonTexts} />
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const faqQuestions = document.querySelectorAll(".faq_question");
        faqQuestions.forEach((btn) => {
          btn.addEventListener("click", () => {
            const wasActive = btn.classList.contains("active");
            faqQuestions.forEach((q) => {
              q.classList.remove("active");
              const ans = q.nextElementSibling;
              if (ans) ans.classList.remove("open");
            });
            if (!wasActive) {
              btn.classList.add("active");
              const answer = btn.nextElementSibling;
              if (answer) answer.classList.add("open");
            }
          });
        });
      });
    </script>
  </body>
</html>
