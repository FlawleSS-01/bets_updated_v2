---
import Container from "@/components/common/Container/Container.astro";
import Footer from "@/components/common/Footer/Footer.astro";
import Logo from "@/components/ui/Logo/Logo.astro";
import Button from "@/components/ui/Button/Button.astro";
import { defaultLng, supportedLanguages } from "@/config/language";
import { routes } from "@/config/routes";
import { getPathWithoutLanguage } from "@/lib/getPathWithoutLang";
import { Nav } from "@/reactComponents/Nav";
import type { SchemaI } from "@/types/structure";
import type { CommonTextsI } from "@/types/texts";
import type { MetatagsI } from "@/components/common/MetaTags";
import MetaTags from "@/components/common/MetaTags/MetaTags.astro";
import Header from "@/components/common/Header/Header.astro";
import "./styles.css";

interface Props {
  schema: SchemaI;
  commonTexts: CommonTextsI;
  metatags: MetatagsI;
}

const { schema, commonTexts, metatags } = Astro.props as Props;

const { lang } = Astro.params;
const currentLang = lang || defaultLng;

const currentPath = getPathWithoutLanguage(
  Astro.url.pathname,
  supportedLanguages,
);

const pages = routes;
const pagesLabel = commonTexts.pages;
const actions = commonTexts.actions;

const navItems = Object.entries(pages)
  .filter(([, cfg]) => !cfg.navHidden)
  .map(([key, cfg]) => ({
    key,
    label: pagesLabel[key] || cfg.label,
    href: `/${currentLang}/${key === "home" ? "" : key}`,
    active: currentPath === `/${key}` || (key === "home" && currentPath === "/"),
  }));
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <MetaTags {...metatags} />

    {schema?.website && (
      <script type="application/ld+json" set:html={JSON.stringify(schema.website)} />
    )}
    {schema?.organization && (
      <script type="application/ld+json" set:html={JSON.stringify(schema.organization)} />
    )}
    {schema?.faqPage && (
      <script type="application/ld+json" set:html={JSON.stringify(schema.faqPage)} />
    )}
    {schema?.breadcrumbList && (
      <script type="application/ld+json" set:html={JSON.stringify(schema.breadcrumbList)} />
    )}
    {schema?.webPage && (
      <script type="application/ld+json" set:html={JSON.stringify(schema.webPage)} />
    )}
    {schema?.SoftwareApplication && (
      <script type="application/ld+json" set:html={JSON.stringify(schema.SoftwareApplication)} />
    )}

    
  
<!-- FAVICONS START -->
  <link rel="icon" type="image/x-icon" href="/favicons/favicon.ico">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/favicons/favicon-48x48.png">
  <link rel="manifest" href="/favicons/manifest.webmanifest">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#fff">
  <meta name="application-name">
  <link rel="apple-touch-icon" sizes="57x57" href="/favicons/apple-touch-icon-57x57.png">
  <link rel="apple-touch-icon" sizes="60x60" href="/favicons/apple-touch-icon-60x60.png">
  <link rel="apple-touch-icon" sizes="72x72" href="/favicons/apple-touch-icon-72x72.png">
  <link rel="apple-touch-icon" sizes="76x76" href="/favicons/apple-touch-icon-76x76.png">
  <link rel="apple-touch-icon" sizes="114x114" href="/favicons/apple-touch-icon-114x114.png">
  <link rel="apple-touch-icon" sizes="120x120" href="/favicons/apple-touch-icon-120x120.png">
  <link rel="apple-touch-icon" sizes="144x144" href="/favicons/apple-touch-icon-144x144.png">
  <link rel="apple-touch-icon" sizes="152x152" href="/favicons/apple-touch-icon-152x152.png">
  <link rel="apple-touch-icon" sizes="167x167" href="/favicons/apple-touch-icon-167x167.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon-180x180.png">
  <link rel="apple-touch-icon" sizes="1024x1024" href="/favicons/apple-touch-icon-1024x1024.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title">
  <meta name="msapplication-TileColor" content="transparent">
  <meta name="msapplication-TileImage" content="/favicons/mstile-144x144.png">
  <meta name="msapplication-config" content="/favicons/browserconfig.xml">
  <!-- FAVICONS END -->
</head>
  <body>
    <Header>
      <Container>
        <div class="header-inner">
          <div class="header-logo">
            <Logo lang={currentLang} />
          </div>

          <Nav client:load navItems={navItems}>
            <Fragment slot="actions">
              <Button lang={currentLang} href="/login" variant="ghost" size="xs" component="a">
                {actions["login"]}
              </Button>
              <Button lang={currentLang} href="/login" size="xs" component="a">
                {actions["register"]}
              </Button>
            </Fragment>
          </Nav>
        </div>
      </Container>
    </Header>

    <main>
      <slot />
    </main>

    <Footer
      lang={currentLang}
      columns={commonTexts.footer.columns}
      copyright={commonTexts.footer.copyright}
      specialBtn={commonTexts.specialBtn}
    />

    <script>
      window.addEventListener("scroll", () => {
        const header = document.getElementById("header");
        if (header) {
          header.classList.toggle("scrolled", window.scrollY > 50);
        }
      });

      function toggleFaq(el: HTMLElement) {
        const item = el.parentElement;
        if (!item) return;
        const wasActive = item.classList.contains("active");
        document.querySelectorAll(".faq-item").forEach((i) => i.classList.remove("active"));
        if (!wasActive) item.classList.add("active");
      }

      (window as any).toggleFaq = toggleFaq;
    </script>
  </body>
</html>
