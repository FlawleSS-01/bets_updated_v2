---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title?: string;
  text?: string;
  paragraphs?: string[];
  listItems?: { title: string; description: string }[];
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
  isMainTitle?: boolean;
  imagePriority?: boolean;
  showButton?: boolean;
  reverse?: boolean;
}

const {
  title,
  text,
  paragraphs = [],
  listItems = [],
  imageSrc,
  imageAlt = "",
  imageTitle = "",
  isMainTitle = false,
  imagePriority = false,
  showButton = false,
  reverse = false,
} = Astro.props;

const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
const refUrl = import.meta.env.PUBLIC_REF || "#";
---

<section class="hYnoSImClkRQlNw">
  <div class="PRGliFfylsNouJK">
    <div class:list={["knSTBEpKQbnwZKI", reverse && "section--reverse"]}>
      {title && isMainTitle && <h1 class="sgsdgsd">{title}</h1>}
      {title && !isMainTitle && <h2 class="kFnVgmqaUEjdlHu">{title}</h2>}

      {fmt && (
        <a href={refUrl} rel="nofollow" class="jnGYfOsDyLXarre" target="_blank">
          <picture>
            <source type="image/avif" srcset={fmt.avif} />
            <source type="image/webp" srcset={fmt.webp} />
            <img
              src={fmt.original}
              alt={imageAlt}
              title={imageTitle}
              loading={imagePriority ? "eager" : "lazy"}
              fetchpriority={imagePriority ? "high" : "low"}
              decoding="async"
              width="600"
              height="336"
            />
          </picture>
        </a>
      )}

      {paragraphs.length > 0 &&
        paragraphs.map((p) => <p class="section__text" set:html={p} />)}

      {!paragraphs.length && text && (
        <p class="section__text" set:html={text} />
      )}

      {listItems.length > 0 && (
        <ul class="section__list">
          {listItems.map((item) => (
            <li class="section__list-item">
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </li>
          ))}
        </ul>
      )}

      {showButton && (
        <div class="section__buttons">
          <ButtonsGroup />
        </div>
      )}
    </div>
  </div>
</section>
