---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title?: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
  showButton?: boolean;
}

const { title = "", description = "", imageSrc, imageAlt = "", imageTitle = "", showButton = false } = Astro.props;
const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
---

{(title || description) && (
  <section class="vblock vspot">
    <div class="vcontainer vspot__grid">
      <div class="vspot__content">
        {title && <h2 class="vspot__title">{title}</h2>}
        {description && <p class="vspot__desc">{description}</p>}
        {showButton && <div class="vspot__cta"><ButtonsGroup /></div>}
      </div>
      {fmt && (
        <div class="vspot__media" aria-hidden="true">
          <picture>
            <source type="image/avif" srcset={fmt.avif} />
            <source type="image/webp" srcset={fmt.webp} />
            <img class="vspot__img" src={fmt.original} alt={imageAlt} title={imageTitle} loading="lazy" decoding="async" width="600" height="336" />
          </picture>
        </div>
      )}
    </div>
  </section>
)}
