---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title?: string;
  description?: string;
  items?: { title: string; description: string }[];
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
  showButton?: boolean;
}

const { title = "", description = "", items = [], imageSrc, imageAlt = "", imageTitle = "", showButton = false } = Astro.props;
const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
---

{(title || items.length > 0) && (
  <section class="vblock vgloss">
    <div class="vcontainer vgloss__grid">
      <div class="vgloss__left">
        {title && <h2 class="vgloss__title">{title}</h2>}
        {description && <p class="vgloss__desc">{description}</p>}
        {items.length > 0 && (
          <div class="vgloss__acc">
            {items.map((it) => (
              <details class="vgloss__item">
                <summary class="vgloss__summary">
                  <span class="vgloss__q">{it.title}</span>
                  <span class="vgloss__icon" aria-hidden="true">+</span>
                </summary>
                <div class="vgloss__a">{it.description}</div>
              </details>
            ))}
          </div>
        )}
        {showButton && (
          <div class="vgloss__cta"><ButtonsGroup /></div>
        )}
      </div>
      {fmt && (
        <div class="vgloss__right" aria-hidden="true">
          <picture>
            <source type="image/avif" srcset={fmt.avif} />
            <source type="image/webp" srcset={fmt.webp} />
            <img class="vgloss__img" src={fmt.original} alt={imageAlt} title={imageTitle} loading="lazy" decoding="async" width="600" height="336" />
          </picture>
        </div>
      )}
    </div>
  </section>
)}
