---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title?: string;
  description?: string;
  items?: { title: string; description: string }[];
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
  showButton?: boolean;
  reverse?: boolean;
}

const { title = "", description = "", items = [], imageSrc, imageAlt = "", imageTitle = "", showButton = false, reverse = false } = Astro.props;
const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
---

{(title || items.length > 0) && (
  <section class="vblock vsteps">
    <div class:list={["vcontainer vsteps__grid", reverse && "vsteps--rev"]}>
      <div class="vsteps__left">
        {title && <h2 class="vsteps__title">{title}</h2>}
        {description && <p class="vsteps__desc">{description}</p>}
        {items.length > 0 && (
          <ol class="vsteps__list">
            {items.map((it, idx) => (
              <li class="vsteps__li">
                <div class="vsteps__num">{idx + 1}</div>
                <div class="vsteps__body">
                  <div class="vsteps__t">{it.title}</div>
                  <div class="vsteps__d">{it.description}</div>
                </div>
              </li>
            ))}
          </ol>
        )}
        {showButton && (
          <div class="vsteps__cta"><ButtonsGroup /></div>
        )}
      </div>
      {fmt && (
        <div class="vsteps__right" aria-hidden="true">
          <picture>
            <source type="image/avif" srcset={fmt.avif} />
            <source type="image/webp" srcset={fmt.webp} />
            <img class="vsteps__img" src={fmt.original} alt={imageAlt} title={imageTitle} loading="lazy" decoding="async" width="600" height="336" />
          </picture>
        </div>
      )}
    </div>
  </section>
)}
