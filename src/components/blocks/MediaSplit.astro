---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { srcSetFrom, pickLargest } from "@/lib/srcset";

interface Props {
  title?: string;
  paragraphs?: string[];
  imageSet?: Record<string, string>;
  imageAlt?: string;
  imageTitle?: string;
  showButton?: boolean;
  reverse?: boolean;
}

const {
  title = "",
  paragraphs = [],
  imageSet,
  imageAlt = "",
  imageTitle = "",
  showButton = false,
  reverse = false,
} = Astro.props;

const imgSrc = pickLargest(imageSet);
const fallbackSrc = imageSet?.[360] ?? imgSrc;
---

{(title || paragraphs.length > 0 || imageSet) && (
  <section class="vblock vmedia">
    <div class:list={["vcontainer vmedia__grid", reverse && "is-reverse"]}>
      <div class="vmedia__text">
        {title && <h2 class="vmedia__title">{title}</h2>}
        {paragraphs.length > 0 && (
          <div class="vmedia__copy">
            {paragraphs.map((p) => (
              <p class="vmedia__p">{p}</p>
            ))}
          </div>
        )}
        {showButton && (
          <div class="vmedia__cta">
            <ButtonsGroup />
          </div>
        )}
      </div>

      <div class="vmedia__media" aria-hidden="true">
        <div class="vmedia__card">
          {imgSrc && (
            <img
              class="vmedia__img"
              src={fallbackSrc}
              srcset={srcSetFrom(imageSet)}
              sizes="(max-width: 1020px) calc(100vw - 68px), 520px"
              alt={imageAlt}
              title={imageTitle}
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              width="600"
              height="336"
            />
          )}
        </div>
      </div>
    </div>
  </section>
)}
