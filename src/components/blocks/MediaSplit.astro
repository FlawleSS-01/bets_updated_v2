---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title?: string;
  paragraphs?: string[];
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
  showButton?: boolean;
  reverse?: boolean;
}

const {
  title = "",
  paragraphs = [],
  imageSrc,
  imageAlt = "",
  imageTitle = "",
  showButton = false,
  reverse = false,
} = Astro.props;

const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
---

{(title || paragraphs.length > 0 || imageSrc) && (
  <section class="vblock vmedia">
    <div class:list={["vcontainer vmedia__grid", reverse && "is-reverse"]}>
      <div class="vmedia__text">
        {title && <h2 class="vmedia__title">{title}</h2>}
        {paragraphs.length > 0 && (
          <div class="vmedia__copy">
            {paragraphs.map((p) => (
              <p class="vmedia__p">{p}</p>
            ))}
          </div>
        )}
        {showButton && (
          <div class="vmedia__cta">
            <ButtonsGroup />
          </div>
        )}
      </div>

      <div class="vmedia__media" aria-hidden="true">
        <div class="vmedia__card">
          {fmt && (
            <picture>
              <source type="image/avif" srcset={fmt.avif} />
              <source type="image/webp" srcset={fmt.webp} />
              <img
                class="vmedia__img"
                src={fmt.original}
                alt={imageAlt}
                title={imageTitle}
                loading="lazy"
                decoding="async"
                width="600"
                height="336"
              />
            </picture>
          )}
        </div>
      </div>
    </div>
  </section>
)}
