---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title?: string;
  description?: string;
  items?: { title: string; description: string }[];
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
  showButton?: boolean;
}

const { title = "", description = "", items = [], imageSrc, imageAlt = "", imageTitle = "", showButton = false } = Astro.props;
const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
---

{(title || items.length > 0) && (
  <section class="vblock vgcg">
    <div class="vcontainer vgcg__grid">
      <div class="vgcg__left">
        {title && <h2 class="vgcg__title">{title}</h2>}
        {description && <p class="vgcg__desc">{description}</p>}
        {items.length > 0 && (
          <div class="vgcg__cards">
            {items.map((it) => (
              <article class="vgcg__card">
                <h3 class="vgcg__cardTitle">{it.title}</h3>
                <p class="vgcg__cardText">{it.description}</p>
              </article>
            ))}
          </div>
        )}
        {showButton && (
          <div class="vgcg__cta"><ButtonsGroup /></div>
        )}
      </div>
      {fmt && (
        <div class="vgcg__right" aria-hidden="true">
          <picture>
            <source type="image/avif" srcset={fmt.avif} />
            <source type="image/webp" srcset={fmt.webp} />
            <img class="vgcg__img" src={fmt.original} alt={imageAlt} title={imageTitle} loading="lazy" decoding="async" width="600" height="336" />
          </picture>
        </div>
      )}
    </div>
  </section>
)}
