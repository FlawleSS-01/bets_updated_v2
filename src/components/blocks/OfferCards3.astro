---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";

interface Props {
  title?: string;
  description?: string;
  items?: { title: string; description: string }[];
  showButton?: boolean;
}

const { title = "", description = "", items = [], showButton = false } = Astro.props;
const cards = (items || []).slice(0, 3);
---

{(title || description || cards.length > 0) && (
  <section class="vblock voffers">
    <div class="vcontainer">
      <header class="voffers__head">
        {title && <h2 class="voffers__title">{title}</h2>}
        {description && <p class="voffers__desc">{description}</p>}
      </header>
      {cards.length > 0 && (
        <div class="voffers__grid">
          {cards.map((it, idx) => (
            <article class="voffers__card">
              <div class="voffers__icon" aria-hidden="true">{idx + 1}</div>
              <h3 class="voffers__cardTitle">{it.title}</h3>
              <p class="voffers__cardText">{it.description}</p>
            </article>
          ))}
        </div>
      )}
      {showButton && (
        <div class="voffers__cta"><ButtonsGroup /></div>
      )}
    </div>
  </section>
)}
