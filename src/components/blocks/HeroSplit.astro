---
import ButtonsGroup from "@/components/ui/ButtonsGroup/ButtonsGroup.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  imageAlt?: string;
  imageTitle?: string;
}

const { title, description, imageSrc, imageAlt = "", imageTitle = "" } = Astro.props;
const fmt = imageSrc ? deriveFormats(imageSrc) : undefined;
const refUrl = import.meta.env.PUBLIC_REF || "#";
---

<section class="vblock vhero">
  <div class="vcontainer vhero__grid">
    <div class="vhero__left">
      {title && <h1 class="vhero__title">{title}</h1>}
      {description && <p class="vhero__desc">{description}</p>}
      <div class="vhero__cta">
        <ButtonsGroup />
      </div>
    </div>
    <div class="vhero__right">
      <div class="vhero__card" aria-hidden="true">
        {fmt && (
          <a href={refUrl} rel="nofollow" target="_blank">
            <picture>
              <source type="image/avif" srcset={fmt.avif} />
              <source type="image/webp" srcset={fmt.webp} />
              <img
                class="vhero__img"
                src={fmt.original}
                alt={imageAlt}
                title={imageTitle}
                loading="lazy"
                decoding="async"
                width="600"
                height="336"
              />
            </picture>
          </a>
        )}
      </div>
    </div>
  </div>
</section>
