---
import Button from "@/components/ui/Button/Button.astro";

interface Props {
  lang: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  buttonText?: string;
  buttonHref?: string;
  reverse?: boolean;
}

const {
  lang,
  title,
  description,
  image,
  imageAlt,
  buttonText,
  buttonHref,
  reverse = false,
} = Astro.props;

function resolveHref(href?: string): string | undefined {
  if (!href) return undefined;
  if (href.endsWith(".apk")) return import.meta.env.PUBLIC_APP;
  return "/go";
}
---

<section class="content-section">
  <div class:list={["container", "content-grid", reverse && "content-grid--reverse"]}>
    <div class="content-text">
      <h2 class="content-title">{title}</h2>
      <p class="content-desc">{description}</p>
      {buttonText && buttonHref && (
        <div class="content-cta">
          <Button lang={lang} href={resolveHref(buttonHref)} component="a">
            {buttonText}
          </Button>
        </div>
      )}
    </div>

    {image && (
      <div class="content-media">
        <div class="content-card">
          <img src={image} alt={imageAlt || title} loading="lazy" class="content-img" />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .content-section {
    padding: 60px 24px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
  }

  .content-grid--reverse .content-text {
    order: 2;
  }

  .content-grid--reverse .content-media {
    order: 1;
  }

  .content-title {
    font-size: 34px;
    font-weight: 800;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .content-desc {
    font-size: 17px;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 20px;
  }

  .content-cta {
    margin-top: 8px;
  }

  .content-card {
    border-radius: 16px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 10px;
  }

  .content-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }

  @media (max-width: 920px) {
    .content-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .content-grid--reverse .content-text,
    .content-grid--reverse .content-media {
      order: unset;
    }

    .content-title {
      font-size: 28px;
    }
  }
</style>
