---
import SectionHeader from "@/components/ui/SectionHeader/SectionHeader.astro";

interface StepItem {
  title: string;
  description: string;
}

interface Props {
  tag?: string;
  tagIcon?: string;
  title: string;
  description?: string;
  items: StepItem[];
}

const { tag, tagIcon, title, description, items } = Astro.props;
---

<section class="steps-section">
  <div class="container">
    <SectionHeader tag={tag} tagIcon={tagIcon} title={title} description={description} />

    <div class="steps-list">
      {items.map((item, i) => (
        <div class="step-item">
          <div class="step-num">{i + 1}</div>
          <div class="step-content">
            <h3 class="step-title">{item.title}</h3>
            <p class="step-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .steps-section {
    padding: 80px 24px;
  }

  .steps-list {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .step-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    padding: 16px 20px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    align-items: start;
  }

  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: var(--link-hover-bg);
    font-weight: 800;
    font-size: 18px;
    color: var(--btn-bg);
  }

  .step-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .step-desc {
    font-size: 15px;
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }
</style>
