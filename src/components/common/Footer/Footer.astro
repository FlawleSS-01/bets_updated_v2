---
import Logo from "@/components/ui/Logo/Logo.astro";
import SocialLinks from "@/components/ui/SocialLinks/SocialLinks.astro";

interface Props {
  lang: string;
  texts: any;
}

const { lang, texts } = Astro.props;
const refUrl = "/go";

const methods = [
  { s: "met1_80", m: "met1_160", alt: "methods" },
  { s: "met2_80", m: "met2_160", alt: "methods" },
  { s: "met3_80", m: "met3_160", alt: "methods" },
  { s: "met4_80", m: "met4_160", alt: "methods" },
  { s: "met5_80", m: "met5_160", alt: "methods" },
  { s: "met6_80", m: "met6_160", alt: "methods" },
  { s: "met7_80", m: "met7_160", alt: "methods" },
  { s: "met8_80", m: "met8_160", alt: "methods" },
  { s: "met9_80", m: "met9_160", alt: "methods" },
  { s: "met10_80", m: "met10_160", alt: "methods" },
  { s: "met11_80", m: "met11_160", alt: "methods" },
];
---

<footer class="footer-1">
  <div class="footer-1__container">
    <div class="footer-1__body">
      <div class="methods">
        <div class="methods_container">
          <h2 class="methods_title">{texts.footer.paymentMethodsTitle}</h2>
          <div class="methods_wrap">
            {methods.map((m) => (
              <a
                href={refUrl}
                class="methods_link"
                rel="nofollow"
                target="_blank"
              >
                <img
                  src={m.s}
                  srcset={`${m.s} 80w, ${m.m} 160w`}
                  sizes="(max-width: 768px) 80px, 80px"
                  alt={m.alt}
                  class="methods_img"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  width="80"
                  height="45"
                />
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="footer_nav_wrap">
        <div class="footer-1__wrap">
          <div class="footer-1__menu-heading">{texts.footer.navigation}</div>
          <ul class="footer-1__menu">
            <li class="footer-1__menu-item">
              <a href={`/${lang}`} class="footer-1__menu-link">
                {texts.footer.links.home}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href={`/${lang}/casino`} class="footer-1__menu-link">
                {texts.footer.links.casino}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href={`/${lang}/login`} class="footer-1__menu-link">
                {texts.footer.links.login}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href={`/${lang}/app`} class="footer-1__menu-link">
                {texts.footer.links.app}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href={`/${lang}/betting`} class="footer-1__menu-link">
                {texts.footer.links.betting}
              </a>
            </li>
          </ul>
        </div>

        <div class="footer-1__wrap_social">
          <SocialLinks />
        </div>

        <div class="footer-1__wrap">
          <Logo lang={lang} className="footer-1__logo" />
        </div>
      </div>
    </div>

    <div class="footer-1__bottom">
      <div class="footer-1__eight footer-1__eight_2">
        <p>{texts.footer.ageNotice}</p>
      </div>
      <div class="footer-1__links">
        <div class="footer-1__link">{texts.footer.ageLimit}</div>
      </div>
    </div>
  </div>

  <a href="/go" rel="nofollow" class="fav pulse" target="_blank">
    <img src="/img/tel.svg" alt="Contact" width="30" height="30" />
  </a>
</footer>
