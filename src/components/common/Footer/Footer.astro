---
import Logo from "@/components/ui/Logo/Logo.astro";
import SocialLinks from "@/components/ui/SocialLinks/SocialLinks.astro";
import { deriveFormats } from "@/lib/picture";

interface Props {
  texts: any;
}

const { texts } = Astro.props;
const refUrl = import.meta.env.PUBLIC_REF || "#";

const methods = Array.from({ length: 11 }, (_, i) => `/img/met${i + 1}.png`);
---

<footer class="footer-1">
  <div class="footer-1__container">
    <div class="footer-1__body">
      <div class="methods">
        <div class="methods_container">
          <h2 class="methods_title">{texts.footer.paymentMethodsTitle}</h2>
          <div class="methods_wrap">
            {methods.map((src) => {
              const fmt = deriveFormats(src);
              return (
                <a
                  href={refUrl}
                  class="methods_link"
                  rel="nofollow"
                  target="_blank"
                >
                  <picture>
                    <source type="image/avif" srcset={fmt.avif} />
                    <source type="image/webp" srcset={fmt.webp} />
                    <img
                      src={fmt.original}
                      alt="Payment method"
                      class="methods_img"
                      loading="lazy"
                      decoding="async"
                      width="80"
                      height="45"
                    />
                  </picture>
                </a>
              );
            })}
          </div>
        </div>
      </div>

      <div class="footer_nav_wrap">
        <div class="footer-1__wrap">
          <div class="footer-1__menu-heading">{texts.footer.navigation}</div>
          <ul class="footer-1__menu">
            <li class="footer-1__menu-item">
              <a href="/" class="footer-1__menu-link">
                {texts.footer.links.home}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href="/casino" class="footer-1__menu-link">
                {texts.footer.links.casino}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href="/login" class="footer-1__menu-link">
                {texts.footer.links.login}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href="/app" class="footer-1__menu-link">
                {texts.footer.links.app}
              </a>
            </li>
            <li class="footer-1__menu-item">
              <a href="/betting" class="footer-1__menu-link">
                {texts.footer.links.betting}
              </a>
            </li>
          </ul>
        </div>

        <div class="footer-1__wrap_social">
          <SocialLinks />
        </div>

        <div class="footer-1__wrap">
          <Logo className="footer-1__logo" />
        </div>
      </div>
    </div>

    <div class="footer-1__bottom">
      <div class="footer-1__eight footer-1__eight_2">
        <p>{texts.footer.ageNotice}</p>
      </div>
      <div class="footer-1__links">
        <div class="footer-1__link">{texts.footer.ageLimit}</div>
      </div>
    </div>
  </div>

  <a href={refUrl} rel="nofollow" class="fav pulse" target="_blank">
    <img src="/img/tel.svg" alt="Contact" width="30" height="30" />
  </a>
</footer>
