---
import { deriveFormats } from "@/lib/picture";

interface Props {
  texts: {
    title: string;
    subtitle: string;
    buttonText: string;
    ariaLabel: string;
    alt: string;
  };
}

const { texts } = Astro.props;
const refUrl = import.meta.env.PUBLIC_REF || "#";

const bannerSrc = "/img/banner.png";
const fmt = deriveFormats(bannerSrc);
---

<section class="intro_banner">
  <a
    href={refUrl}
    class="intro_banner_full_link"
    rel="nofollow"
    aria-label={texts.ariaLabel}
    target="_blank"
  />

  <picture>
    <source type="image/avif" srcset={fmt.avif} />
    <source type="image/webp" srcset={fmt.webp} />
    <img
      src={fmt.original}
      alt={texts.alt}
      class="intro_banner_bg"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="600"
      height="336"
    />
  </picture>

  <div class="intro_banner_container">
    <p class="intro_banner_title">{texts.title}</p>
    <p class="intro_banner_subtitle">{texts.subtitle}</p>
  </div>

  <a href={refUrl} rel="nofollow" class="intro_banner_link" target="_blank">
    {texts.buttonText}
  </a>
</section>
