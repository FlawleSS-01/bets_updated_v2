---
export interface Props {
  lang: string;
  component?: "button" | "a" | "span";
  href?: string;
  variant?: "primary" | "ghost" | "outline";
  size?: "xs" | "lg";
}

const {
  lang,
  href,
  size,
  component = "button",
  variant = "primary",
} = Astro.props as Props;

const appPath = import.meta.env.PUBLIC_APP;
const isApk = href?.endsWith(".apk");

const rel =
  href?.includes("/go") || href?.startsWith("https://")
    ? "noopener noreferrer nofollow"
    : null;

const target =
  href?.includes("/go") || href?.startsWith("https://") ? "_blank" : undefined;

const classList = [
  "btn",
  variant === "primary" && "btn-primary",
  variant === "ghost" && "btn-ghost",
  variant === "outline" && "btn-outline",
  size === "xs" && "btn-xs",
  size === "lg" && "btn-lg",
];

let link = isApk ? appPath : href;

if (href === import.meta.env.PUBLIC_REF) link = "/go";
else if (
  href &&
  !href.startsWith("http") &&
  !isApk &&
  href !== "/go"
)
  link = `/${lang}/${href.replace(/^\//g, "")}`;
---

{href ? (
  <a
    href={link}
    class:list={classList}
    rel={rel}
    download={isApk ? `${import.meta.env.PUBLIC_BRAND}.apk` : false}
    target={target}
  >
    <slot />
  </a>
) : component === "button" ? (
  <button class:list={classList}>
    <slot />
  </button>
) : (
  <span class:list={classList}>
    <slot />
  </span>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 15px;
    transition: all 0.3s;
    cursor: pointer;
    border: none;
    text-decoration: none;
    line-height: 1;
  }

  .btn-primary {
    background: var(--btn-bg);
    color: var(--btn-text);
    text-shadow: 0 0 3px rgba(0, 0, 0, 0.5);
  }

  .btn-primary:hover {
    background: var(--btn-hover-bg);
    transform: translateY(-2px);
  }

  .btn-ghost {
    background: transparent;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .btn-outline {
    background: transparent;
    color: var(--btn-bg);
    border: 2px solid var(--btn-bg);
  }

  .btn-outline:hover {
    background: var(--link-hover-bg);
  }

  .btn-xs {
    padding: 8px 18px;
    font-size: 14px;
  }

  .btn-lg {
    padding: 16px 36px;
    font-size: 16px;
  }
</style>
