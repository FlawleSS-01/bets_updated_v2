---
import type { MetatagsI } from "@/components/common/MetaTags";
import Banner from "@/components/common/Banner/Banner.astro";
import HeroSplit from "@/components/blocks/HeroSplit.astro";
import StatsStrip from "@/components/blocks/StatsStrip.astro";
import BlocksRenderer from "@/components/blocks/BlocksRenderer.astro";
import FaqSection from "@/components/blocks/FaqSection.astro";
import { defaultLng, supportedLanguages } from "@/config/language";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getText } from "@/locales/getText";
import { buildSeoSchema } from "@/lib/seoSchema";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
  return supportedLanguages.map((lang) => ({ params: { lang } }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const langCode = lang.split("-")[0] || defaultLng.split("-")[0];

const commonTexts = await getText(langCode, "common");
const metaCanons = await import("P/canon.json");
const pageData = await getText(langCode, "home");

const baseUrl = import.meta.env.PUBLIC_DOMAIN?.replace(/\/$/, "") || "";
const brandName = import.meta.env.PUBLIC_BRAND || "";

const imageMapHome: Record<string, Record<number, string>> = {
  main:  { 360: "hero_360",  460: "hero_460",  600: "hero_600"  },
  main1: { 360: "head1_360", 460: "head1_460", 600: "head1_600" },
  main2: { 360: "head2_360", 460: "head2_460", 600: "head2_600" },
  main3: { 360: "head3_360", 460: "head3_460", 600: "head3_600" },
  main4: { 360: "head4_360", 460: "head4_460", 600: "head4_600" },
  main5: { 360: "head5_360", 460: "head5_460", 600: "head5_600" },
  main6: { 360: "head6_360", 460: "head6_460", 600: "head6_600" },
};

const imageDescription = commonTexts.imageDescription?.home || {};
const getImageMeta = (key: string) => imageDescription[key] || { alt: "", title: "" };
const getImageSet = (key: string): Record<string, string> | undefined =>
  imageMapHome[key] as Record<string, string> | undefined;

const h1ImageSet = getImageSet(pageData.h1Image);

const schema = buildSeoSchema({
  page: "home",
  baseUrl,
  brandName,
  lang,
  title: pageData.title,
  description: pageData.description,
  faqItems: commonTexts.faq?.items,
});

const metaTags: MetatagsI = {
  title: pageData.title,
  descr: pageData.description,
  metaCanons: (metaCanons as any).home,
};

const siteSeed = [brandName, baseUrl, lang].join("|");
---

<BaseLayout commonTexts={commonTexts} schema={schema} metatags={metaTags}>
  <Banner texts={commonTexts.banner} />

  {(pageData.h1 || pageData.h1Description) && (
    <HeroSplit
      title={pageData.h1}
      description={pageData.h1Description}
      imageSet={h1ImageSet}
      imageAlt={getImageMeta(pageData.h1Image)?.alt}
      imageTitle={getImageMeta(pageData.h1Image)?.title}
    />
  )}

  <StatsStrip items={pageData.stats || []} />

  <BlocksRenderer
    blocks={pageData.blocks || []}
    getImageSet={getImageSet}
    getImageMeta={getImageMeta}
    seed={siteSeed}
    pageKey="home"
  />

  <FaqSection title={commonTexts.faq.title} items={commonTexts.faq.items} />
</BaseLayout>
