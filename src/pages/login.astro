---
import type { MetatagsI } from "@/components/common/MetaTags";
import Banner from "@/components/common/Banner/Banner.astro";
import Section from "@/components/blocks/Section.astro";
import BlocksRenderer from "@/components/blocks/BlocksRenderer.astro";
import { defaultLng } from "@/config/language";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getText } from "@/locales/getText";
import { buildSeoSchema } from "@/lib/seoSchema";

export const prerender = true;

const lang = defaultLng;
const langCode = lang.split("-")[0] || "en";

const commonTexts = await getText(langCode, "common");
const metaCanons = await import("P/canon.json");
const pageData = await getText(langCode, "login");

const baseUrl = import.meta.env.PUBLIC_DOMAIN?.replace(/\/$/, "") || "";
const brandName = import.meta.env.PUBLIC_BRAND || "";

const imageDescription = commonTexts.imageDescription?.login || {};
const getImageMeta = (key: string) => {
  const filename = key.split("/").pop() || key;
  return imageDescription[filename] || imageDescription[key] || { alt: "", title: "" };
};

const h1ImageSrc = pageData.h1Image ? `/img/${pageData.h1Image}` : undefined;

const schema = buildSeoSchema({
  page: "login",
  baseUrl,
  brandName,
  lang,
  title: pageData.title,
  description: pageData.description,
});

const metaTags: MetatagsI = {
  title: pageData.title,
  descr: pageData.description,
  metaCanons: (metaCanons as any).login,
};

const siteSeed = [brandName, baseUrl, lang].join("|");
---

<BaseLayout commonTexts={commonTexts} schema={schema} metatags={metaTags}>
  <Banner texts={commonTexts.banner} />

  {(pageData.h1 || pageData.h1Description) && (
    <Section
      title={pageData.h1}
      text={pageData.h1Description}
      isMainTitle={true}
      imageSrc={h1ImageSrc}
      imageAlt={getImageMeta(pageData.h1Image)?.alt}
      imageTitle={getImageMeta(pageData.h1Image)?.title}
      imagePriority={true}
      showButton={true}
    />
  )}

  <BlocksRenderer
    blocks={pageData.blocks || []}
    getImageMeta={getImageMeta}
    seed={siteSeed}
    pageKey="login"
  />
</BaseLayout>
